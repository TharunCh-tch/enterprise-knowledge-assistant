# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Enterprise Knowledge Assistant"
APP_VERSION="1.0.0"

# ─── Models ───────────────────────────────────────────────────────────────────
# Embedding model (HuggingFace sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM for answer generation
# Light (CPU-friendly):  google/flan-t5-base  (~300 MB)
# Better quality:        google/flan-t5-large  (~800 MB)
# Best quality (local):  google/flan-t5-xl     (~3 GB)
LLM_MODEL=google/flan-t5-base
LLM_MAX_NEW_TOKENS=256

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=3

# ─── Uploads ──────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
